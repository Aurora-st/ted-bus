############################################
# Bus Travel Platform Backend (Production)
############################################

NODE_ENV=production
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster-host>/<db>?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-me-use-32plus-bytes

# Frontend (Netlify) for CORS
FRONTEND_URL=https://<your-netlify-site>.netlify.app

# Google Maps (optional for route planning)
GOOGLE_MAPS_API_KEY=

# Cloudinary (Phase 4)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (required for production verification + notifications email channel)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Metrics (Grafana Agent / Prometheus scrape)
# If set, /metrics requires Authorization: Bearer <token>
METRICS_TOKEN=

